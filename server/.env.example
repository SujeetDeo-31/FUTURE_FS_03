# ── Database ─────────────────────────────────────────────────
# MongoDB Atlas connection string (replace with your cluster URI)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── CORS ─────────────────────────────────────────────────────
# Your deployed frontend URL (no trailing slash)
CORS_ORIGIN=https://your-domain.com

# ── JWT / Session Security ───────────────────────────────────
# Use a long, random secret in production (min 32 chars)
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d

# ── Admin Bootstrap ──────────────────────────────────────────
# Used one-time to create the first admin account via POST /api/auth/admin-signup
ADMIN_BOOTSTRAP_SECRET=change_this_to_a_strong_secret


RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@yourdomain.com
OWNER_EMAIL=owner@yourdomain.com

# ── Site URL (used in email links) ────────────────────────────
# Your deployed frontend URL — shown in email links to redirect users
SITE_URL=https://your-domain.com
